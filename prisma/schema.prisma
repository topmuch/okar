generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  name             String?
  phone            String?
  password         String?
  role             String             @default("driver")
  garageId         String?
  emailVerified    Boolean            @default(false)
  phoneVerified    Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  blogPosts        BlogPost[]
  dailyReports     DailyReport[]
  fleetAccounts    FleetAccount[]
  fleetMemberships FleetMember[]
  assignedLeads    Lead[]             @relation("AssignedLeads")
  loginLogs        LoginLog[]
  observations     Observation[]
  reminderLogs     ReminderLog[]
  sessions         Session[]
  transactions     Transaction[]
  garage           Garage?            @relation(fields: [garageId], references: [id], onDelete: Cascade)
  notifications    UserNotification[]
  ownedVehicles    Vehicle[]          @relation("VehicleProprietor")
  vehicles         Vehicle[]          @relation("VehicleOwner")

  @@index([email])
  @@index([phone])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  userAgent    String?
  ipAddress    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id            String   @id @default(cuid())
  userId        String?
  email         String
  success       Boolean  @default(false)
  failureReason String?
  ipAddress     String?
  userAgent     String?
  country       String?
  city          String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}

model Garage {
  id                    String              @id @default(cuid())
  name                  String
  slug                  String              @unique
  email                 String?
  phone                 String?
  address               String?
  logo                  String?
  isCertified           Boolean             @default(false)
  businessLicense       String?
  subscriptionPlan      String?             @default("basic")
  subscriptionExpiresAt DateTime?
  active                Boolean             @default(true)
  whatsappNumber        String?
  whatsappVerified      Boolean             @default(false)
  
  // Champs pour le flux d'inscription sécurisé
  managerName           String?             // Nom du gérant
  managerPhone          String?             // Téléphone du gérant
  businessRegistryNumber String?            // Numéro de registre de commerce / agrément
  shopPhoto             String?             // Photo de la façade du garage
  idDocumentUrl         String?             // Pièce d'identité du gérant
  agreementDocumentUrl  String?             // Photo de l'agrément
  validationStatus      String              @default("PENDING")  // PENDING, APPROVED, REJECTED
  rejectionReason       String?             // Motif de rejet si applicable
  validatedAt           DateTime?           // Date de validation
  validatedBy           String?             // ID de l'admin qui a validé
  temporaryPassword     String?             // Mot de passe temporaire généré
  
  // PARTIE 1.5 - SUSPENSION MANUELLE (Monétisation)
  accountStatus         String              @default("ACTIVE")  // ACTIVE, SUSPENDED_BY_ADMIN
  suspendedAt           DateTime?
  suspendedBy           String?             // ID de l'admin qui a suspendu
  suspensionReason      String?
  contractEndDate       DateTime?           // Date de fin de contrat (informatif)
  
  // PARTIE 2.7 - Géolocalisation pour Urgence Panne
  latitude              Float?
  longitude             Float?
  geoUpdatedAt          DateTime?
  
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  profile               GarageProfile?
  invoices              Invoice[]
  maintenanceRecords    MaintenanceRecord[] @relation("GarageRecords")
  assignedLots          QRCodeLot[]
  qrCodes               QRCodeStock[]
  transactions          Transaction[]
  users                 User[]
  vehicles              Vehicle[]
  auditLogs             AuditLog[]
  qrSwapRequests        QRSwapRequest[]

  @@index([slug])
  @@index([isCertified])
  @@index([validationStatus])
  @@index([accountStatus])
}

model QRCodeLot {
  id           String        @id @default(cuid())
  prefix       String
  count        Int
  status       String        @default("CREATED")
  assignedToId String?
  assignedAt   DateTime?
  createdBy    String?
  createdAt    DateTime      @default(now())
  expiresAt    DateTime?
  notes        String?
  assignedTo   Garage?       @relation(fields: [assignedToId], references: [id])
  qrCodes      QRCodeStock[]
  vehicles     Vehicle[]

  @@index([status])
}

model QRCodeStock {
  id               String       @id @default(cuid())
  codeUnique       String       @unique
  shortCode        String       @unique
  lotId            String
  status           String       @default("STOCK")  // STOCK, ASSIGNED, ACTIVE, LOST, REVOKED, SWAPPED
  assignedGarageId String?
  linkedVehicleId  String?      @unique
  activationDate   DateTime?
  revokedAt        DateTime?
  revokedBy        String?
  revokeReason     String?
  replacementForId String?      @unique
  printedAt        DateTime?
  printedBy        String?
  
  // PARTIE 1.4 - QR Codes Perdus/Volés
  lostAt           DateTime?
  markedLostBy     String?      // ID de l'utilisateur qui a marqué comme perdu
  lostReason       String?
  swappedToId      String?      @unique  // ID du nouveau QR en cas de swap
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  replacementFor   QRCodeStock? @relation("QRReplacement", fields: [replacementForId], references: [id])
  replacedBy       QRCodeStock? @relation("QRReplacement")
  linkedVehicle    Vehicle?     @relation("VehicleQRCode", fields: [linkedVehicleId], references: [id])
  assignedGarage   Garage?      @relation(fields: [assignedGarageId], references: [id])
  lot              QRCodeLot    @relation(fields: [lotId], references: [id])

  @@index([codeUnique])
  @@index([shortCode])
  @@index([status])
}

model Vehicle {
  id                     String              @id @default(cuid())
  reference              String              @unique
  type                   String              @default("voiture")
  vin                    String?             @unique
  make                   String?
  model                  String?
  year                   Int?
  color                  String?
  licensePlate           String?
  engineType             String?             @default("essence")
  engineCapacity         String?
  fuelType               String?
  currentMileage         Int                 @default(0)
  mileageUpdatedAt       DateTime?
  mainPhoto              String?
  vtStartDate            DateTime?
  vtEndDate              DateTime?
  vtCenter               String?
  vtDocumentUrl          String?
  insuranceStartDate     DateTime?
  insuranceEndDate       DateTime?
  insuranceCompany       String?
  insurancePolicyNum     String?
  insuranceDocumentUrl   String?
  nextMaintenanceDueKm   Int?
  nextMaintenanceDueDate DateTime?
  nextMaintenanceType    String?
  lastMaintenanceKm      Int?
  lastMaintenanceDate    DateTime?
  lastMaintenanceType    String?
  ownerId                String?
  proprietorId           String?
  ownerName              String?
  ownerFirstName         String?
  ownerLastName          String?
  ownerPhone             String?
  ownerEmail             String?
  garageId               String?
  lotId                  String?
  qrStatus               String              @default("INACTIVE")
  status                 String              @default("pending_activation")
  lastScanDate           DateTime?
  lastLocation           String?
  declaredLostAt         DateTime?
  foundAt                DateTime?
  activatedAt            DateTime?
  
  // PARTIE 2.6 - Score de Santé OKAR (Gamification)
  okarScore              Int                 @default(0)      // Score 0-100
  okarBadge              String?             // BRONZE, SILVER, GOLD
  scoreUpdatedAt         DateTime?
  
  createdAt              DateTime            @default(now())
  expiresAt              DateTime?
  updatedAt              DateTime            @updatedAt
  fleetVehicles          FleetVehicle[]
  leadRequests           LeadRequest[]
  maintenanceRecords     MaintenanceRecord[]
  ownershipHistory       OwnershipHistory[]
  pdfReports             PdfReport[]
  qrCode                 QRCodeStock?        @relation("VehicleQRCode")
  reminderLogs           ReminderLog[]
  notifications          UserNotification[]
  proprietor             User?               @relation("VehicleProprietor", fields: [proprietorId], references: [id])
  owner                  User?               @relation("VehicleOwner", fields: [ownerId], references: [id])
  lot                    QRCodeLot?          @relation(fields: [lotId], references: [id])
  garage                 Garage?             @relation(fields: [garageId], references: [id])
  photos                 VehiclePhoto[]
  sale                   VehicleSale?
  transferCodes          TransferCode[]
  accessTickets          AccessTicket[]

  @@index([reference])
  @@index([licensePlate])
  @@index([ownerId])
  @@index([proprietorId])
  @@index([garageId])
  @@index([vtEndDate])
  @@index([insuranceEndDate])
  @@index([okarScore])
}

model VehiclePhoto {
  id         String   @id @default(cuid())
  vehicleId  String
  url        String
  caption    String?
  isMain     Boolean  @default(false)
  uploadedBy String?
  uploadedAt DateTime @default(now())
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model MaintenanceRecord {
  id                String              @id @default(cuid())
  vehicleId         String
  garageId          String?
  mechanicName      String?
  mechanicSignature String?
  mechanicPhone     String?
  category          String
  subCategory       String?
  description       String?
  mileage           Int?
  partsList         String?             // Ancien champ texte (deprecated)
  partsListJson     String?             // PARTIE 2.8 - Nouveau champ JSON structuré
  partsCost         Float?              @default(0)
  laborCost         Float?              @default(0)
  totalCost         Float?              @default(0)
  invoicePhoto      String?
  invoiceNumber     String?
  workPhotos        String?
  status            String              @default("PENDING")  // PENDING, VALIDATED, ARCHIVED
  ownerValidation   String              @default("PENDING")
  isLocked          Boolean             @default(false)
  
  // PARTIE 1.2 - Historique Antérieur (Véhicules sans historique)
  source            String              @default("OKAR")    // OKAR, PRE_OKAR_PAPER
  paperDocumentUrl  String?             // URL du document papier scanné
  isVerified        Boolean             @default(false)     // Vérifié visuellement
  
  serverCreatedAt   DateTime            @default(now())
  serverValidatedAt DateTime?
  correctionOfId    String?
  correctionReason  String?
  interventionDate  DateTime            @default(now())
  validationDate    DateTime?
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  correctionOf      MaintenanceRecord?  @relation("RecordCorrection", fields: [correctionOfId], references: [id])
  correctedBy       MaintenanceRecord[] @relation("RecordCorrection")
  vehicle           Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  garage            Garage?             @relation("GarageRecords", fields: [garageId], references: [id])

  @@index([vehicleId])
  @@index([garageId])
  @@index([status])
  @@index([interventionDate])
  @@index([isLocked])
  @@index([source])
}

model OwnershipHistory {
  id                String   @id @default(cuid())
  vehicleId         String
  previousOwnerId   String?
  previousOwnerName String?
  newOwnerId        String?
  newOwnerName      String?
  newOwnerPhone     String?
  transferType      String   @default("sale")
  transferDate      DateTime @default(now())
  transferPrice     Float?
  documentUrl       String?
  createdAt         DateTime @default(now())
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model ReminderLog {
  id              String    @id @default(cuid())
  vehicleId       String
  type            String
  channel         String
  recipient       String
  message         String
  status          String    @default("PENDING")
  errorDetails    String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  webhookResponse String?
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([type])
  @@index([status])
  @@index([sentAt])
}

model UserNotification {
  id        String    @id @default(cuid())
  userId    String?
  vehicleId String?
  type      String
  title     String
  message   String
  data      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  type      String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String
  category    String   @default("general")
  enabled     Boolean  @default(false)
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id                String   @id @default(cuid())
  type              String
  status            String   @default("non_lu")
  senderName        String?
  senderEmail       String?
  senderPhone       String?
  garageId          String?
  recipientGarageId String?
  subject           String?
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  garageId  String?
  vehicleId String?
  message   String
  data      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailSettings {
  id             String    @id @default(cuid())
  provider       String    @default("console")
  fromEmail      String    @default("noreply@okar.sn")
  fromName       String    @default("OKAR")
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPassword   String?
  smtpEncryption String    @default("tls")
  isActive       Boolean   @default(true)
  lastTestAt     DateTime?
  lastTestStatus String?
  lastTestError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model EmailLog {
  id        String    @id @default(cuid())
  to        String
  subject   String
  type      String
  status    String    @default("pending")
  error     String?
  userId    String?
  garageId  String?
  data      String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model EmailToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  type      String
  code      String?
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Invoice {
  id            String    @id @default(cuid())
  number        String    @unique
  garageId      String
  amount        Float
  currency      String    @default("XOF")
  status        String    @default("pending")
  description   String?
  items         String
  dueDate       DateTime?
  paidAt        DateTime?
  paymentMethod String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  garage        Garage    @relation(fields: [garageId], references: [id])
}

model Lead {
  id           String        @id @default(cuid())
  name         String
  email        String
  phone        String?
  company      String?
  status       String        @default("new")
  source       String?
  notes        String?
  garageId     String?
  assignedToId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  assignedTo   User?         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  observations Observation[]
}

model Observation {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  content   String
  date      DateTime @default(now())
  userId    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Advertisement {
  id            String         @id @default(cuid())
  title         String
  description   String?
  imageUrl      String
  linkUrl       String?
  linkTarget    String         @default("_blank")
  position      String         @default("footer")
  targetScope   String         @default("all")
  garageId      String?
  startDate     DateTime
  endDate       DateTime?
  status        String         @default("draft")
  priority      Int            @default(0)
  impressions   Int            @default(0)
  clicks        Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  adImpressions AdImpression[]
}

model AdImpression {
  id              String        @id @default(cuid())
  advertisementId String
  userId          String?
  garageId        String?
  userRole        String?
  action          String
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String
  excerpt     String?
  coverImage  String?
  category    String     @default("actualites")
  status      String     @default("draft")
  publishedAt DateTime?
  authorId    String?
  views       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  author      User?      @relation(fields: [authorId], references: [id])
  blogViews   BlogView[]
}

model BlogView {
  id        String   @id @default(cuid())
  postId    String
  userId    String?
  garageId  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String     @id @default(cuid())
  userId          String?
  garageId        String?
  amount          Float
  currency        String     @default("XOF")
  provider        String
  providerRef     String?
  type            String
  status          String     @default("PENDING")
  metadata        String?
  payerPhone      String?
  payerName       String?
  webhookReceived Boolean    @default(false)
  webhookData     String?
  promoCodeId     String?
  promoDiscount   Float?     @default(0)
  initiatedAt     DateTime   @default(now())
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  pdfReport       PdfReport?
  garage          Garage?    @relation(fields: [garageId], references: [id])
  user            User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([garageId])
  @@index([type])
  @@index([status])
  @@index([provider])
  @@index([providerRef])
}

model GarageProfile {
  id                    String    @id @default(cuid())
  garageId              String    @unique
  subscriptionTier      String    @default("FREE")
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  subscriptionAutoRenew Boolean   @default(false)
  profileViews          Int       @default(0)
  qrScans               Int       @default(0)
  contactClicks         Int       @default(0)
  statsViews            String?
  promoCredits          Int       @default(0)
  promoCreditsUsed      Int       @default(0)
  badgeVerified         Boolean   @default(false)
  badgeRecommended      Boolean   @default(false)
  badgeTopRated         Boolean   @default(false)
  promoActive           Boolean   @default(false)
  promoMessage          String?
  promoEndDate          DateTime?
  appointmentEnabled    Boolean   @default(false)
  appointmentPhone      String?
  appointmentWhatsapp   String?
  specialties           String?
  workingHours          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  garage                Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([subscriptionTier])
  @@index([subscriptionEndDate])
}

model VehicleSale {
  id                 String    @id @default(cuid())
  vehicleId          String    @unique
  isForSale          Boolean   @default(false)
  salePrice          Float?
  saleCurrency       String    @default("XOF")
  saleDescription    String?
  contactPhone       String?
  contactWhatsapp    String?
  isBoosted          Boolean   @default(false)
  boostStartDate     DateTime?
  boostEndDate       DateTime?
  boostType          String?
  verificationStatus String    @default("NONE")
  verificationDate   DateTime?
  verificationReport String?
  verifiedBy         String?
  viewCount          Int       @default(0)
  contactCount       Int       @default(0)
  whatsappShares     Int       @default(0)
  adContextTags      String?
  publishedAt        DateTime?
  soldAt             DateTime?
  archivedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  vehicle            Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([isForSale])
  @@index([isBoosted])
  @@index([verificationStatus])
}

model LeadRequest {
  id                String    @id @default(cuid())
  vehicleId         String
  userId            String?
  type              String
  status            String    @default("NEW")
  partnerId         String?
  partnerName       String?
  partnerCommission Float?
  vehicleMake       String?
  vehicleModel      String?
  vehicleYear       Int?
  vehiclePlate      String?
  ownerPhone        String?
  ownerEmail        String?
  ownerName         String?
  location          String?
  sentToPartnerAt   DateTime?
  partnerResponseAt DateTime?
  conversionDate    DateTime?
  conversionValue   Float?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([type])
  @@index([status])
  @@index([partnerId])
}

model FleetAccount {
  id                    String         @id @default(cuid())
  companyName           String
  companyEmail          String?
  companyPhone          String?
  companyAddress        String?
  businessType          String?
  adminUserId           String
  subscriptionTier      String         @default("BASIC")
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  vehiclesIncluded      Int            @default(1)
  vehiclesUsed          Int            @default(0)
  pricePerVehicle       Float          @default(1000)
  totalVehicles         Int            @default(0)
  activeVehicles        Int            @default(0)
  totalMileage          Int            @default(0)
  pendingAlerts         Int            @default(0)
  lastAlertDate         DateTime?
  lastExportDate        DateTime?
  exportFormat          String         @default("CSV")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  adminUser             User           @relation(fields: [adminUserId], references: [id])
  members               FleetMember[]
  vehicles              FleetVehicle[]

  @@index([adminUserId])
  @@index([subscriptionEndDate])
}

model FleetVehicle {
  id                 String       @id @default(cuid())
  fleetAccountId     String
  vehicleId          String
  assignedDriverId   String?
  assignedDriverName String?
  internalId         String?
  notes              String?
  monthlyMileage     Int          @default(0)
  maintenanceCount   Int          @default(0)
  active             Boolean      @default(true)
  addedAt            DateTime     @default(now())
  removedAt          DateTime?
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  fleetAccount       FleetAccount @relation(fields: [fleetAccountId], references: [id], onDelete: Cascade)

  @@unique([fleetAccountId, vehicleId])
  @@index([fleetAccountId])
  @@index([vehicleId])
}

model FleetMember {
  id               String       @id @default(cuid())
  fleetAccountId   String
  userId           String
  role             String       @default("VIEWER")
  canExport        Boolean      @default(false)
  canManageDrivers Boolean      @default(false)
  invitedBy        String?
  invitedAt        DateTime     @default(now())
  acceptedAt       DateTime?
  active           Boolean      @default(true)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fleetAccount     FleetAccount @relation(fields: [fleetAccountId], references: [id], onDelete: Cascade)

  @@unique([fleetAccountId, userId])
  @@index([fleetAccountId])
  @@index([userId])
}

model AdCampaign {
  id                String                 @id @default(cuid())
  name              String
  advertiserName    String
  advertiserEmail   String?
  advertiserPhone   String?
  targetCategory    String?
  targetLocation    String?
  targetVehicleType String?
  creativeType      String                 @default("IMAGE")
  creativeUrl       String?
  creativeAlt       String?
  headline          String?
  description       String?
  ctaText           String?
  ctaUrl            String?
  pricingModel      String                 @default("CPM")
  budgetTotal       Float
  budgetSpent       Float                  @default(0)
  costPerUnit       Float                  @default(0)
  impressions       Int                    @default(0)
  clicks            Int                    @default(0)
  conversions       Int                    @default(0)
  ctr               Float                  @default(0)
  startDate         DateTime
  endDate           DateTime?
  status            String                 @default("DRAFT")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  adImpressions     AdCampaignImpression[]

  @@index([targetCategory])
  @@index([targetLocation])
  @@index([status])
}

model AdCampaignImpression {
  id         String     @id @default(cuid())
  campaignId String
  vehicleId  String?
  userId     String?
  action     String
  ipAddress  String?
  userAgent  String?
  referrer   String?
  createdAt  DateTime   @default(now())
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([vehicleId])
  @@index([action])
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Float
  maxUses       Int?
  usesCount     Int      @default(0)
  applicableTo  String
  validFrom     DateTime
  validUntil    DateTime
  isActive      Boolean  @default(true)
  minAmount     Float?
  maxDiscount   Float?
  firstTimeOnly Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model PdfReport {
  id               String       @id @default(cuid())
  vehicleId        String
  transactionId    String?      @unique
  reportType       String
  includePhotos    Boolean      @default(true)
  includeCharts    Boolean      @default(true)
  fileName         String
  fileUrl          String
  fileSize         Int?
  certifiedAt      DateTime?
  certifiedBy      String?
  verificationCode String?      @unique
  accessCount      Int          @default(0)
  lastAccessedAt   DateTime?
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
  vehicle          Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([verificationCode])
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String   // APPROVE_GARAGE, REJECT_GARAGE, CREATE_USER, etc.
  entityType   String   // GARAGE, USER, VEHICLE, etc.
  entityId     String   // ID de l'entité concernée
  userId       String?  // ID de l'utilisateur qui a effectué l'action
  userEmail    String?  // Email de l'utilisateur
  details      String?  // Détails supplémentaires en JSON
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  garageId     String?
  garage       Garage?  @relation(fields: [garageId], references: [id])

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

// PARTIE 1.1 - Ticket d'Accès Client
model AccessTicket {
  id                String   @id @default(cuid())
  vehicleId         String
  garageId          String
  driverName        String
  driverPhone       String
  driverEmail       String?
  vehicleInfo       String   // "Toyota Corolla - AA-1234-BB"
  qrReference       String
  tempPassword      String
  generatedAt       DateTime @default(now())
  sentViaWhatsApp   Boolean  @default(false)
  sentViaSMS        Boolean  @default(false)
  printedAt         DateTime?
  expiresAt         DateTime?
  createdBy         String?  // ID de l'utilisateur garage
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@index([vehicleId])
  @@index([driverPhone])
  @@index([generatedAt])
}

// PARTIE 1.3 - Code de Transfert Sécurisé
model TransferCode {
  id              String   @id @default(cuid())
  code            String   @unique  // Code à 6 chiffres
  vehicleId       String
  sellerId        String   // ID du propriétaire actuel
  sellerName      String
  sellerPhone     String
  buyerId         String?  // ID du nouveau propriétaire (rempli à la saisie)
  buyerName       String?
  buyerPhone      String?
  status          String   @default("PENDING")  // PENDING, USED, EXPIRED, CANCELLED
  createdAt       DateTime @default(now())
  expiresAt       DateTime  // 48h par défaut
  usedAt          DateTime?
  confirmedBy     String?  // ID du vendeur qui a confirmé
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@index([code])
  @@index([vehicleId])
  @@index([sellerId])
  @@index([status])
  @@index([expiresAt])
}

// PARTIE 1.4 - Demande de remplacement QR
model QRSwapRequest {
  id              String   @id @default(cuid())
  vehicleId       String
  oldQrCodeId     String
  newQrCodeId     String?
  requesterId     String   // ID du propriétaire
  requesterPhone  String
  reason          String   // ENDOMMAGE, PERDU, ILLISIBLE
  status          String   @default("PENDING")  // PENDING, APPROVED, COMPLETED, REJECTED
  adminNotes      String?
  createdAt       DateTime @default(now())
  processedAt     DateTime?
  processedBy     String?  // ID de l'admin
  garageId        String?
  garage          Garage?  @relation(fields: [garageId], references: [id])
  
  @@index([vehicleId])
  @@index([requesterId])
  @@index([status])
}
