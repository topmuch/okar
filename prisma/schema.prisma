generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AccessTicket {
  id              String    @id
  vehicleId       String
  garageId        String
  driverName      String
  driverPhone     String
  driverEmail     String?
  vehicleInfo     String
  qrReference     String
  tempPassword    String
  generatedAt     DateTime  @default(now())
  sentViaWhatsApp Boolean   @default(false)
  sentViaSMS      Boolean   @default(false)
  printedAt       DateTime?
  expiresAt       DateTime?
  createdBy       String?
  Vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([driverPhone])
  @@index([generatedAt])
}

model AdCampaign {
  id                   String                 @id
  name                 String
  advertiserName       String
  advertiserEmail      String?
  advertiserPhone      String?
  targetCategory       String?
  targetLocation       String?
  targetVehicleType    String?
  creativeType         String                 @default("IMAGE")
  creativeUrl          String?
  creativeAlt          String?
  headline             String?
  description          String?
  ctaText              String?
  ctaUrl               String?
  pricingModel         String                 @default("CPM")
  budgetTotal          Float
  budgetSpent          Float                  @default(0)
  costPerUnit          Float                  @default(0)
  impressions          Int                    @default(0)
  clicks               Int                    @default(0)
  conversions          Int                    @default(0)
  ctr                  Float                  @default(0)
  startDate            DateTime
  endDate              DateTime?
  status               String                 @default("DRAFT")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  AdCampaignImpression AdCampaignImpression[]

  @@index([targetCategory])
  @@index([targetLocation])
  @@index([status])
}

model AdCampaignImpression {
  id         String     @id
  campaignId String
  vehicleId  String?
  userId     String?
  action     String
  ipAddress  String?
  userAgent  String?
  referrer   String?
  createdAt  DateTime   @default(now())
  AdCampaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([vehicleId])
  @@index([action])
}

model AdImpression {
  id              String        @id
  advertisementId String
  userId          String?
  garageId        String?
  userRole        String?
  action          String
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  Advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
}

model Advertisement {
  id           String         @id
  title        String
  description  String?
  imageUrl     String
  linkUrl      String?
  linkTarget   String         @default("_blank")
  position     String         @default("footer")
  targetScope  String         @default("all")
  garageId     String?
  startDate    DateTime
  endDate      DateTime?
  status       String         @default("draft")
  priority     Int            @default(0)
  impressions  Int            @default(0)
  clicks       Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  AdImpression AdImpression[]
}

model AuditLog {
  id         String   @id
  action     String
  entityType String
  entityId   String
  userId     String?
  userEmail  String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  garageId   String?
  Garage     Garage?  @relation(fields: [garageId], references: [id])

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

model Banner {
  id        String   @id
  type      String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model BlogPost {
  id          String     @id
  title       String
  slug        String     @unique
  content     String
  excerpt     String?
  coverImage  String?
  category    String     @default("actualites")
  status      String     @default("draft")
  publishedAt DateTime?
  authorId    String?
  views       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  User        User?      @relation(fields: [authorId], references: [id])
  BlogView    BlogView[]
}

model BlogView {
  id        String   @id
  postId    String
  userId    String?
  garageId  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  BlogPost  BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model BroadcastNotification {
  id              String    @id
  title           String
  message         String
  type            String
  targetScope     String
  targetFilters   String?
  channels        String
  scheduledAt     DateTime?
  sentAt          DateTime?
  status          String    @default("DRAFT")
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  deliveredCount  Int       @default(0)
  failedCount     Int       @default(0)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([status])
  @@index([targetScope])
  @@index([scheduledAt])
}

model DailyReport {
  id        String   @id
  userId    String
  date      DateTime @default(now())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model DashboardStats {
  id                  String   @id
  date                DateTime @unique
  totalVehicles       Int      @default(0)
  newVehicles         Int      @default(0)
  totalGarages        Int      @default(0)
  activeGarages       Int      @default(0)
  pendingGarages      Int      @default(0)
  suspendedGarages    Int      @default(0)
  totalQR             Int      @default(0)
  activeQR            Int      @default(0)
  pendingQR           Int      @default(0)
  totalInterventions  Int      @default(0)
  pendingValidations  Int      @default(0)
  totalUsers          Int      @default(0)
  newUsers            Int      @default(0)
  dailyRevenue        Float    @default(0)
  monthlyRevenue      Float    @default(0)
  vtExpiring7         Int      @default(0)
  vtExpiring30        Int      @default(0)
  insuranceExpiring7  Int      @default(0)
  insuranceExpiring30 Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime

  @@index([date])
}

model EmailLog {
  id        String    @id
  to        String
  subject   String
  type      String
  status    String    @default("pending")
  error     String?
  userId    String?
  garageId  String?
  data      String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model EmailSettings {
  id             String    @id
  provider       String    @default("console")
  fromEmail      String    @default("noreply@okar.sn")
  fromName       String    @default("OKAR")
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPassword   String?
  smtpEncryption String    @default("tls")
  isActive       Boolean   @default(true)
  lastTestAt     DateTime?
  lastTestStatus String?
  lastTestError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
}

model EmailToken {
  id        String    @id
  email     String
  token     String    @unique
  type      String
  code      String?
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model ExpirationAlert {
  id            String    @id
  vehicleId     String
  type          String
  expiryDate    DateTime
  daysRemaining Int
  firstAlertAt  DateTime?
  secondAlertAt DateTime?
  finalAlertAt  DateTime?
  status        String    @default("PENDING")
  resolvedAt    DateTime?
  channelsUsed  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([vehicleId])
  @@index([type])
  @@index([expiryDate])
  @@index([status])
}

model FeatureFlag {
  id          String   @id
  key         String   @unique
  label       String
  description String
  category    String   @default("general")
  enabled     Boolean  @default(false)
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model FleetAccount {
  id                    String         @id
  companyName           String
  companyEmail          String?
  companyPhone          String?
  companyAddress        String?
  businessType          String?
  adminUserId           String
  subscriptionTier      String         @default("BASIC")
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  vehiclesIncluded      Int            @default(1)
  vehiclesUsed          Int            @default(0)
  pricePerVehicle       Float          @default(1000)
  totalVehicles         Int            @default(0)
  activeVehicles        Int            @default(0)
  totalMileage          Int            @default(0)
  pendingAlerts         Int            @default(0)
  lastAlertDate         DateTime?
  lastExportDate        DateTime?
  exportFormat          String         @default("CSV")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime
  User                  User           @relation(fields: [adminUserId], references: [id])
  FleetMember           FleetMember[]
  FleetVehicle          FleetVehicle[]

  @@index([adminUserId])
  @@index([subscriptionEndDate])
}

model FleetMember {
  id               String       @id
  fleetAccountId   String
  userId           String
  role             String       @default("VIEWER")
  canExport        Boolean      @default(false)
  canManageDrivers Boolean      @default(false)
  invitedBy        String?
  invitedAt        DateTime     @default(now())
  acceptedAt       DateTime?
  active           Boolean      @default(true)
  User             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  FleetAccount     FleetAccount @relation(fields: [fleetAccountId], references: [id], onDelete: Cascade)

  @@unique([fleetAccountId, userId])
  @@index([fleetAccountId])
  @@index([userId])
}

model FleetVehicle {
  id                 String       @id
  fleetAccountId     String
  vehicleId          String
  assignedDriverId   String?
  assignedDriverName String?
  internalId         String?
  notes              String?
  monthlyMileage     Int          @default(0)
  maintenanceCount   Int          @default(0)
  active             Boolean      @default(true)
  addedAt            DateTime     @default(now())
  removedAt          DateTime?
  Vehicle            Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  FleetAccount       FleetAccount @relation(fields: [fleetAccountId], references: [id], onDelete: Cascade)

  @@unique([fleetAccountId, vehicleId])
  @@index([fleetAccountId])
  @@index([vehicleId])
}

model Garage {
  id                     String              @id
  name                   String
  slug                   String              @unique
  email                  String?
  phone                  String?
  address                String?
  logo                   String?
  isCertified            Boolean             @default(false)
  businessLicense        String?
  subscriptionPlan       String?             @default("basic")
  subscriptionExpiresAt  DateTime?
  active                 Boolean             @default(true)
  whatsappNumber         String?
  whatsappVerified       Boolean             @default(false)
  managerName            String?
  managerPhone           String?
  businessRegistryNumber String?
  shopPhoto              String?
  idDocumentUrl          String?
  agreementDocumentUrl   String?
  validationStatus       String              @default("PENDING")
  rejectionReason        String?
  validatedAt            DateTime?
  validatedBy            String?
  temporaryPassword      String?
  accountStatus          String              @default("ACTIVE")
  suspendedAt            DateTime?
  suspendedBy            String?
  suspensionReason       String?
  contractEndDate        DateTime?
  latitude               Float?
  longitude              Float?
  geoUpdatedAt           DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime
  AuditLog               AuditLog[]
  GarageOnboarding       GarageOnboarding?
  GaragePhoto            GaragePhoto[]
  GarageProfile          GarageProfile?
  GarageRating           GarageRating[]
  GarageService          GarageService[]
  Invoice                Invoice[]
  MaintenanceRecord      MaintenanceRecord[]
  QRCodeLot              QRCodeLot[]
  QRCodeStock            QRCodeStock[]
  QRSwapRequest          QRSwapRequest[]
  Transaction            Transaction[]
  User                   User[]
  Vehicle                Vehicle[]

  @@index([slug])
  @@index([isCertified])
  @@index([validationStatus])
  @@index([accountStatus])
}

model GarageOnboarding {
  id                String    @id
  garageId          String    @unique
  currentStep       Int       @default(1)
  isCompleted       Boolean   @default(false)
  hasTriedDemo      Boolean   @default(false)
  demoVehicleId     String?
  documentsUploaded Boolean   @default(false)
  skippedDocuments  Boolean   @default(false)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Garage            Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

model GaragePhoto {
  id         String   @id
  garageId   String
  url        String
  caption    String?
  isMain     Boolean  @default(false)
  category   String?
  sortOrder  Int      @default(0)
  uploadedAt DateTime @default(now())
  Garage     Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

model GarageProfile {
  id                    String    @id
  garageId              String    @unique
  subscriptionTier      String    @default("FREE")
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  subscriptionAutoRenew Boolean   @default(false)
  profileViews          Int       @default(0)
  qrScans               Int       @default(0)
  contactClicks         Int       @default(0)
  statsViews            String?
  promoCredits          Int       @default(0)
  promoCreditsUsed      Int       @default(0)
  badgeVerified         Boolean   @default(false)
  badgeRecommended      Boolean   @default(false)
  badgeTopRated         Boolean   @default(false)
  promoActive           Boolean   @default(false)
  promoMessage          String?
  promoEndDate          DateTime?
  appointmentEnabled    Boolean   @default(false)
  appointmentPhone      String?
  appointmentWhatsapp   String?
  specialties           String?
  workingHours          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  Garage                Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([subscriptionTier])
  @@index([subscriptionEndDate])
}

model GarageRating {
  id            String    @id
  garageId      String
  vehicleId     String
  maintenanceId String?
  rating        Int
  comment       String?
  reply         String?
  replyAt       DateTime?
  isVerified    Boolean   @default(false)
  helpfulCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  Garage        Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([rating])
  @@index([garageId])
}

model GarageService {
  id          String   @id
  garageId    String
  name        String
  description String?
  icon        String?
  price       Float?
  priceUnit   String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Garage      Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([garageId])
}

model InterventionCategory {
  id                         String                 @id
  name                       String
  slug                       String                 @unique
  icon                       String?
  color                      String?
  parentId                   String?
  isActive                   Boolean                @default(true)
  sortOrder                  Int                    @default(0)
  avgCostMin                 Float?
  avgCostMax                 Float?
  avgDuration                Int?
  usageCount                 Int                    @default(0)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime
  InterventionCategory       InterventionCategory?  @relation("InterventionCategoryToInterventionCategory", fields: [parentId], references: [id])
  other_InterventionCategory InterventionCategory[] @relation("InterventionCategoryToInterventionCategory")

  @@index([isActive])
  @@index([parentId])
}

model Invoice {
  id            String    @id
  number        String    @unique
  garageId      String
  amount        Float
  currency      String    @default("XOF")
  status        String    @default("pending")
  description   String?
  items         String
  dueDate       DateTime?
  paidAt        DateTime?
  paymentMethod String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Garage        Garage    @relation(fields: [garageId], references: [id])
}

model Lead {
  id           String        @id
  name         String
  email        String
  phone        String?
  company      String?
  status       String        @default("new")
  source       String?
  notes        String?
  garageId     String?
  assignedToId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  User         User?         @relation(fields: [assignedToId], references: [id])
  Observation  Observation[]
}

model LeadRequest {
  id                String    @id
  vehicleId         String
  userId            String?
  type              String
  status            String    @default("NEW")
  partnerId         String?
  partnerName       String?
  partnerCommission Float?
  vehicleMake       String?
  vehicleModel      String?
  vehicleYear       Int?
  vehiclePlate      String?
  ownerPhone        String?
  ownerEmail        String?
  ownerName         String?
  location          String?
  sentToPartnerAt   DateTime?
  partnerResponseAt DateTime?
  conversionDate    DateTime?
  conversionValue   Float?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([type])
  @@index([status])
  @@index([partnerId])
}

model LoginLog {
  id            String   @id
  userId        String?
  email         String
  success       Boolean  @default(false)
  failureReason String?
  ipAddress     String?
  userAgent     String?
  country       String?
  city          String?
  createdAt     DateTime @default(now())
  User          User?    @relation(fields: [userId], references: [id])
}

model MaintenanceRecord {
  id                      String              @id
  vehicleId               String
  garageId                String?
  mechanicName            String?
  mechanicSignature       String?
  mechanicPhone           String?
  category                String
  subCategory             String?
  description             String?
  mileage                 Int?
  partsList               String?
  partsListJson           String?
  partsCost               Float?              @default(0)
  laborCost               Float?              @default(0)
  totalCost               Float?              @default(0)
  invoicePhoto            String?
  invoiceNumber           String?
  workPhotos              String?
  status                  String              @default("PENDING")
  ownerValidation         String              @default("PENDING")
  isLocked                Boolean             @default(false)
  source                  String              @default("OKAR")
  paperDocumentUrl        String?
  isVerified              Boolean             @default(false)
  serverCreatedAt         DateTime            @default(now())
  serverValidatedAt       DateTime?
  correctionOfId          String?
  correctionReason        String?
  interventionDate        DateTime            @default(now())
  validationDate          DateTime?
  rejectionReason         String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime
  MaintenanceRecord       MaintenanceRecord?  @relation("MaintenanceRecordToMaintenanceRecord", fields: [correctionOfId], references: [id])
  other_MaintenanceRecord MaintenanceRecord[] @relation("MaintenanceRecordToMaintenanceRecord")
  Vehicle                 Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  Garage                  Garage?             @relation(fields: [garageId], references: [id])

  @@index([vehicleId])
  @@index([garageId])
  @@index([status])
  @@index([interventionDate])
  @@index([isLocked])
  @@index([source])
}

model Message {
  id                String   @id
  type              String
  status            String   @default("non_lu")
  senderName        String?
  senderEmail       String?
  senderPhone       String?
  garageId          String?
  recipientGarageId String?
  subject           String?
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime
}

model MessageTemplate {
  id         String    @id
  name       String    @unique
  slug       String    @unique
  type       String
  category   String
  subject    String?
  content    String
  variables  String?
  isActive   Boolean   @default(true)
  isDefault  Boolean   @default(false)
  language   String    @default("fr")
  sentCount  Int       @default(0)
  lastSentAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime

  @@index([type])
  @@index([category])
  @@index([isActive])
}

model Notification {
  id        String   @id
  type      String
  userId    String?
  garageId  String?
  vehicleId String?
  message   String
  data      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Observation {
  id        String   @id
  leadId    String
  type      String
  content   String
  date      DateTime @default(now())
  userId    String
  createdAt DateTime @default(now())
  Lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OwnershipHistory {
  id                String   @id
  vehicleId         String
  previousOwnerId   String?
  previousOwnerName String?
  newOwnerId        String?
  newOwnerName      String?
  newOwnerPhone     String?
  transferType      String   @default("sale")
  transferDate      DateTime @default(now())
  transferPrice     Float?
  documentUrl       String?
  createdAt         DateTime @default(now())
  Vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Page {
  id        String   @id
  slug      String   @unique
  title     String
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model PdfReport {
  id               String       @id
  vehicleId        String
  transactionId    String?      @unique
  reportType       String
  includePhotos    Boolean      @default(true)
  includeCharts    Boolean      @default(true)
  fileName         String
  fileUrl          String
  fileSize         Int?
  certifiedAt      DateTime?
  certifiedBy      String?
  verificationCode String?      @unique
  accessCount      Int          @default(0)
  lastAccessedAt   DateTime?
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  Transaction      Transaction? @relation(fields: [transactionId], references: [id])
  Vehicle          Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([verificationCode])
}

model PromoCode {
  id            String   @id
  code          String   @unique
  description   String?
  discountType  String
  discountValue Float
  maxUses       Int?
  usesCount     Int      @default(0)
  applicableTo  String
  validFrom     DateTime
  validUntil    DateTime
  isActive      Boolean  @default(true)
  minAmount     Float?
  maxDiscount   Float?
  firstTimeOnly Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([code])
  @@index([isActive])
}

model QRCodeLot {
  id           String        @id
  prefix       String
  count        Int
  status       String        @default("CREATED")
  assignedToId String?
  assignedAt   DateTime?
  createdBy    String?
  createdAt    DateTime      @default(now())
  expiresAt    DateTime?
  notes        String?
  Garage       Garage?       @relation(fields: [assignedToId], references: [id])
  QRCodeStock  QRCodeStock[]
  Vehicle      Vehicle[]

  @@index([status])
}

model QRCodeStock {
  id                String       @id
  codeUnique        String       @unique
  shortCode         String       @unique
  lotId             String
  status            String       @default("STOCK")
  assignedGarageId  String?
  linkedVehicleId   String?      @unique
  activationDate    DateTime?
  revokedAt         DateTime?
  revokedBy         String?
  revokeReason      String?
  replacementForId  String?      @unique
  printedAt         DateTime?
  printedBy         String?
  lostAt            DateTime?
  markedLostBy      String?
  lostReason        String?
  swappedToId       String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  QRCodeStock       QRCodeStock? @relation("QRCodeStockToQRCodeStock", fields: [replacementForId], references: [id])
  other_QRCodeStock QRCodeStock? @relation("QRCodeStockToQRCodeStock")
  Vehicle           Vehicle?     @relation(fields: [linkedVehicleId], references: [id])
  Garage            Garage?      @relation(fields: [assignedGarageId], references: [id])
  QRCodeLot         QRCodeLot    @relation(fields: [lotId], references: [id])

  @@index([codeUnique])
  @@index([shortCode])
  @@index([status])
}

model QRSwapRequest {
  id             String    @id
  vehicleId      String
  oldQrCodeId    String
  newQrCodeId    String?
  requesterId    String
  requesterPhone String
  reason         String
  status         String    @default("PENDING")
  adminNotes     String?
  createdAt      DateTime  @default(now())
  processedAt    DateTime?
  processedBy    String?
  garageId       String?
  Garage         Garage?   @relation(fields: [garageId], references: [id])

  @@index([vehicleId])
  @@index([requesterId])
  @@index([status])
}

model ReminderLog {
  id              String    @id
  vehicleId       String
  type            String
  channel         String
  recipient       String
  message         String
  status          String    @default("PENDING")
  errorDetails    String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  webhookResponse String?
  userId          String?
  User            User?     @relation(fields: [userId], references: [id])
  Vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([type])
  @@index([status])
  @@index([sentAt])
}

model Report {
  id            String    @id
  type          String
  status        String    @default("PENDING")
  priority      String    @default("NORMAL")
  reporterId    String?
  reporterName  String?
  reporterPhone String?
  reporterEmail String?
  reporterRole  String?
  reportedType  String
  reportedId    String?
  reportedName  String?
  title         String
  description   String
  evidenceUrls  String?
  assignedToId  String?
  adminNotes    String?
  resolution    String?
  resolvedAt    DateTime?
  resolvedBy    String?
  actionTaken   String?
  vehicleId     String?
  garageId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([reportedType])
  @@index([createdAt])
}

model RevenueRecord {
  id            String    @id
  garageId      String?
  type          String
  amount        Float
  currency      String    @default("XOF")
  periodStart   DateTime?
  periodEnd     DateTime?
  paymentStatus String    @default("PENDING")
  paymentMethod String?
  paidAt        DateTime?
  invoiceNumber String?
  invoiceUrl    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([garageId])
  @@index([type])
  @@index([paymentStatus])
  @@index([periodStart])
}

model Session {
  id           String   @id
  userId       String
  userAgent    String?
  ipAddress    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id
  key       String   @unique
  value     String
  updatedAt DateTime
}

model Transaction {
  id              String     @id
  userId          String?
  garageId        String?
  amount          Float
  currency        String     @default("XOF")
  provider        String
  providerRef     String?
  type            String
  status          String     @default("PENDING")
  metadata        String?
  payerPhone      String?
  payerName       String?
  webhookReceived Boolean    @default(false)
  webhookData     String?
  promoCodeId     String?
  promoDiscount   Float?     @default(0)
  initiatedAt     DateTime   @default(now())
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime
  PdfReport       PdfReport?
  Garage          Garage?    @relation(fields: [garageId], references: [id])
  User            User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([garageId])
  @@index([type])
  @@index([status])
  @@index([provider])
  @@index([providerRef])
}

model TransferCode {
  id           String    @id
  code         String    @unique
  vehicleId    String
  sellerId     String
  sellerName   String
  sellerPhone  String
  buyerId      String?
  buyerName    String?
  buyerPhone   String?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  usedAt       DateTime?
  confirmedBy  String?
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  Vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([vehicleId])
  @@index([sellerId])
  @@index([status])
  @@index([expiresAt])
}

model User {
  id                                 String             @id
  email                              String             @unique
  name                               String?
  phone                              String?
  password                           String?
  role                               String             @default("driver")
  garageId                           String?
  emailVerified                      Boolean            @default(false)
  phoneVerified                      Boolean            @default(false)
  createdAt                          DateTime           @default(now())
  updatedAt                          DateTime
  BlogPost                           BlogPost[]
  DailyReport                        DailyReport[]
  FleetAccount                       FleetAccount[]
  FleetMember                        FleetMember[]
  Lead                               Lead[]
  LoginLog                           LoginLog[]
  Observation                        Observation[]
  ReminderLog                        ReminderLog[]
  Session                            Session[]
  Transaction                        Transaction[]
  Garage                             Garage?            @relation(fields: [garageId], references: [id], onDelete: Cascade)
  UserNotification                   UserNotification[]
  Vehicle_Vehicle_proprietorIdToUser Vehicle[]          @relation("Vehicle_proprietorIdToUser")
  Vehicle_Vehicle_ownerIdToUser      Vehicle[]          @relation("Vehicle_ownerIdToUser")

  @@index([email])
  @@index([phone])
  @@index([role])
}

model UserNotification {
  id        String    @id
  userId    String?
  vehicleId String?
  type      String
  title     String
  message   String
  data      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  Vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id])
  User      User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Vehicle {
  id                              String               @id
  reference                       String               @unique
  type                            String               @default("voiture")
  vin                             String?              @unique
  make                            String?
  model                           String?
  year                            Int?
  color                           String?
  licensePlate                    String?
  engineType                      String?              @default("essence")
  engineCapacity                  String?
  fuelType                        String?
  currentMileage                  Int                  @default(0)
  mileageUpdatedAt                DateTime?
  mainPhoto                       String?
  vtStartDate                     DateTime?
  vtEndDate                       DateTime?
  vtCenter                        String?
  vtDocumentUrl                   String?
  insuranceStartDate              DateTime?
  insuranceEndDate                DateTime?
  insuranceCompany                String?
  insurancePolicyNum              String?
  insuranceDocumentUrl            String?
  nextMaintenanceDueKm            Int?
  nextMaintenanceDueDate          DateTime?
  nextMaintenanceType             String?
  lastMaintenanceKm               Int?
  lastMaintenanceDate             DateTime?
  lastMaintenanceType             String?
  ownerId                         String?
  proprietorId                    String?
  ownerName                       String?
  ownerFirstName                  String?
  ownerLastName                   String?
  ownerPhone                      String?
  ownerEmail                      String?
  garageId                        String?
  lotId                           String?
  qrStatus                        String               @default("INACTIVE")
  status                          String               @default("pending_activation")
  lastScanDate                    DateTime?
  lastLocation                    String?
  declaredLostAt                  DateTime?
  foundAt                         DateTime?
  activatedAt                     DateTime?
  okarScore                       Int                  @default(0)
  okarBadge                       String?
  scoreUpdatedAt                  DateTime?
  createdAt                       DateTime             @default(now())
  expiresAt                       DateTime?
  updatedAt                       DateTime
  AccessTicket                    AccessTicket[]
  FleetVehicle                    FleetVehicle[]
  GarageRating                    GarageRating[]
  LeadRequest                     LeadRequest[]
  MaintenanceRecord               MaintenanceRecord[]
  OwnershipHistory                OwnershipHistory[]
  PdfReport                       PdfReport[]
  QRCodeStock                     QRCodeStock?
  ReminderLog                     ReminderLog[]
  TransferCode                    TransferCode[]
  UserNotification                UserNotification[]
  User_Vehicle_proprietorIdToUser User?                @relation("Vehicle_proprietorIdToUser", fields: [proprietorId], references: [id])
  User_Vehicle_ownerIdToUser      User?                @relation("Vehicle_ownerIdToUser", fields: [ownerId], references: [id])
  QRCodeLot                       QRCodeLot?           @relation(fields: [lotId], references: [id])
  Garage                          Garage?              @relation(fields: [garageId], references: [id])
  VehicleHealthAlert              VehicleHealthAlert[]
  VehiclePhoto                    VehiclePhoto[]
  VehicleSale                     VehicleSale?

  @@index([reference])
  @@index([licensePlate])
  @@index([ownerId])
  @@index([proprietorId])
  @@index([garageId])
  @@index([vtEndDate])
  @@index([insuranceEndDate])
  @@index([okarScore])
}

model VehicleHealthAlert {
  id         String    @id
  vehicleId  String
  type       String
  severity   String
  title      String
  message    String
  dueDate    DateTime?
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  Vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([isResolved])
  @@index([severity])
  @@index([vehicleId])
}

model VehiclePhoto {
  id         String   @id
  vehicleId  String
  url        String
  caption    String?
  isMain     Boolean  @default(false)
  uploadedBy String?
  uploadedAt DateTime @default(now())
  Vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehicleSale {
  id                 String    @id
  vehicleId          String    @unique
  isForSale          Boolean   @default(false)
  salePrice          Float?
  saleCurrency       String    @default("XOF")
  saleDescription    String?
  contactPhone       String?
  contactWhatsapp    String?
  isBoosted          Boolean   @default(false)
  boostStartDate     DateTime?
  boostEndDate       DateTime?
  boostType          String?
  verificationStatus String    @default("NONE")
  verificationDate   DateTime?
  verificationReport String?
  verifiedBy         String?
  viewCount          Int       @default(0)
  contactCount       Int       @default(0)
  whatsappShares     Int       @default(0)
  adContextTags      String?
  publishedAt        DateTime?
  soldAt             DateTime?
  archivedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  Vehicle            Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([isForSale])
  @@index([isBoosted])
  @@index([verificationStatus])
}
