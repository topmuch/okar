# ═══════════════════════════════════════════════════════════════════════════════
# OKAR - Docker Ignore
# Files to exclude from Docker build context
# ═══════════════════════════════════════════════════════════════════════════════

# Dependencies
node_modules
.pnp
.pnp.js

# Build outputs
.next
out
build
dist

# Database (will be created in container)
*.db
*.db-journal
prisma/dev.db
prisma/*.db
db/*.db

# Testing
coverage
.nyc_output
*.test.ts
*.spec.ts
__tests__

# Environment files (use Coolify environment variables)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.idea
.vscode
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Docker
Dockerfile
docker-compose*.yml
.docker

# Documentation
README.md
CHANGELOG.md
docs/
*.md

# Logs
logs
*.log
npm-debug.log*

# Misc
.turbo
*.tsbuildinfo
.eslintcache
