# ═══════════════════════════════════════════════════════════════════════════════
# OKAR - Environment Variables Template
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# SQLite (default) - file path relative to project root
DATABASE_URL=file:/app/data/okar.db

# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/okar

# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH.JS (Authentication)
# ─────────────────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION URLS
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────
# Used for encrypting sensitive data
ENCRYPTION_KEY=your-encryption-key-change-me

# ─────────────────────────────────────────────────────────────────────────────
# PAYPAL (Optional)
# ─────────────────────────────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# COOLIFY SPECIFIC
# ─────────────────────────────────────────────────────────────────────────────
# Set by Coolify automatically
# PORT=3000
# HOSTNAME=0.0.0.0
# NODE_ENV=production
